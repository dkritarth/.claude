            </div>
          </article>
        ))}
      </div>

      <div className="mt-10 rounded-sm border border-ink-200 bg-ink-50 px-5 py-4 text-sm text-ink-700">
        Looking for papers and preprints?{' '}
        <a href="/publications/" className="font-semibold text-ink-900 underline underline-offset-2 hover:no-underline">
          View Publications →
        </a>
      </div>
    </Section>
  );
