#!/bin/bash

# Custom statusline: model + context usage %

# Get model from settings or env
model="${CLAUDE_CODE_MODEL:-haiku}"
case "$model" in
  haiku) model_display="Haiku" ;;
  sonnet) model_display="Sonnet" ;;
  opus) model_display="Opus" ;;
  fable) model_display="Fable" ;;
  *) model_display="$model" ;;
esac

# Context usage: read from stdin JSON if available, else show placeholder
context_pct=0
if [ -t 0 ]; then
  # No stdin, show default
  context_pct="?"
else
  # Try to extract context % from stdin (populated by Claude Code for statusLine hooks)
  context_pct=$(jq -r '.context_usage_percent // "?"' 2>/dev/null) || context_pct="?"
fi

# Format: [Model] Context: NN%
echo "[$model_display] Context: ${context_pct}%"
