{
  "model": "haiku",
  "enabledPlugins": {
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "theme": "dark",
  "statusLine": {
    "type": "command",
    "command": "bash /Users/kritarth/.claude/statusline-custom.sh",
    "refreshInterval": 2
  },
  "hooks": {
    "SessionStart": [{
      "hooks": [{
        "type": "command",
        "command": "echo 'full' > ~/.claude/.caveman-mode-active 2>/dev/null || true"
      }]
    }]
  }
}
